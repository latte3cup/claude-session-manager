{
  "productName": "wmux",
  "version": "0.6.3",
  "identifier": "com.wmux.app",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "wmux",
        "width": 900,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "publisher": "Fernando Menuk",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
