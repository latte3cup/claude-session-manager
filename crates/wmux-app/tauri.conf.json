{
  "productName": "Claude Session Manager",
  "version": "0.1.0",
  "identifier": "com.claude-session-manager.app",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Session Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../mcp/dist/bundle*": "mcp/",
      "frontend-mobile/**": "frontend-mobile/",
      "frontend/vendor/**": "frontend/vendor/"
    },
    "publisher": "Fernando Menuk",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
